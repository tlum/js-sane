{
  "name": "@tlum/js-sane",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": "https://github.com/tlum/js-sane.git",
  "version": "0.1.3",
  "description": "Node.js addon scaffold for the Linux SANE API",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "gypfile": true,
  "files": [
    "binding.gyp",
    "dist",
    "src/native",
    "tools/check-libsane.js"
  ],
  "scripts": {
    "install": "npm run build:addon",
    "build": "npm run build:addon && npm run build:ts",
    "prebuild:addon": "node tools/check-libsane.js",
    "build:addon": "node-gyp rebuild",
    "build:ts": "tsc -p tsconfig.json",
    "prepare": "npm run build:ts",
    "prepack": "npm run build:ts",
    "test:pack": "node tools/smoke-pack.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build:ts && node --test test/*.test.mjs"
  },
  "dependencies": {
    "node-addon-api": "^8.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "node-gyp": "^11.2.0",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20"
  }
}
